{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/kimi-k2.6",
  "small_model": "opencode/qwen3.6-plus",
  "instructions": [
    "CLAUDE.md",
    ".github/instructions/*.instructions.md"
  ],
  "permission": {
    "edit": "ask",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "python tools/board/ticket_new.py": "allow",
      "python tools/board/ticket_new.py *": "allow",
      "python tools/board/ticket_move.py": "allow",
      "python tools/board/ticket_move.py *": "allow",
      "python tools/board/board_check.py": "allow",
      "python tools/board/board_check.py *": "allow",
      "python tools/board/ticket_archive.py": "allow",
      "python tools/board/ticket_archive.py *": "allow",
      "python3 tools/board/ticket_new.py": "allow",
      "python3 tools/board/ticket_new.py *": "allow",
      "python3 tools/board/ticket_move.py": "allow",
      "python3 tools/board/ticket_move.py *": "allow",
      "python3 tools/board/board_check.py": "allow",
      "python3 tools/board/board_check.py *": "allow",
      "python3 tools/board/ticket_archive.py": "allow",
      "python3 tools/board/ticket_archive.py *": "allow",
      "cmake *": "allow",
      "ctest *": "allow",
      "pytest *": "allow",
      "python -m pytest *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push": "deny",
      "git push *": "deny"
    }
  },
  "agent": {
    "build": {
      "model": "opencode/big-pickle"
    },
    "plan": {
      "model": "opencode/claude-opus-4-6"
    }
  }
}
